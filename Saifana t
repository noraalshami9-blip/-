    <script>
        function animateValue(id, start, end, duration) {
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                const value = Math.floor(progress * (end - start) + start);
                document.getElementById(id).textContent = value + (id === 'stat2' ? '%' : id === 'stat4' ? '' : '+');
                if (progress < 1) window.requestAnimationFrame(step);
            };
            window.requestAnimationFrame(step);
        }

        let statsAnimated = false;
        window.addEventListener('scroll', () => {
            if (!statsAnimated && window.scrollY > 400) {
                statsAnimated = true;
                animateValue('stat1', 0, 460, 2200);
                animateValue('stat2', 0, 99.5, 2200);
                animateValue('stat3', 0, 34, 2200);
                animateValue('stat4', 0, 5, 2200);
            }
        });

        function submitForm() {
            const msg = document.getElementById('successMsg');
            msg.classList.remove('hidden');
            setTimeout(() => msg.classList.add('hidden'), 8000);
            document.getElementById('contactForm').reset();
        }
